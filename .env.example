# TGA environment example.
# Do not commit real secrets.

TGA_RUN_ROOT=runs
# Explicit MCP allowlist. Defaults to config/mcp.json (empty server set).
TGA_MCP_CONFIG_PATH=config/mcp.json
TGA_MCP_IMPORT_MAX_BYTES=2147483648
# Temporary compatibility switch for the deprecated mcp-security-hub scanner.
TGA_ENABLE_LEGACY_MCP_HUB=false

# Optional OpenAI-compatible model gateway. In the competition, replace these
# with the model API and safety gateway required by the organizer.
TGA_LLM_BASE_URL=
TGA_LLM_API_KEY=
TGA_LLM_MODEL=
TGA_LLM_SUPPORTS_VISION=

# Frontend. Empty means same-origin /api; local dev can use http://127.0.0.1:8000.
VITE_TGA_API_BASE=http://127.0.0.1:8000
